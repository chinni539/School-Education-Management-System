# ============================================================
#  EduCore Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# ============================================================

# ── Supabase / PostgreSQL Connection ─────────────────────────
# Get this from: Supabase Dashboard → Project → Settings → Database
# Use the "Connection string" → "URI" format

DATABASE_URL=postgresql://postgres.sfacxtdtfwqqirjclnqv:RVh2AvjAXPRIrMqw@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&connect_timeout=10

# ── OR use individual fields (either DATABASE_URL or these) ──
# DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-supabase-db-password
# DB_SSL=true

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS: comma-separated allowed origins ────────────────────
# Add your Netlify URL here after deploying frontend
ALLOWED_ORIGINS=https://your-app.netlify.app
