# ============================================================
#  EduCore Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# ============================================================

# ── Supabase / PostgreSQL Connection ─────────────────────────
# Get this from: Supabase Dashboard → Project → Settings → Database
# Use the "Connection string" → "URI" format

DATABASE_URL=postgresql://postgres:Zmalqp$1029$$@db.sfacxtdtfwqqirjclnqv.supabase.co:5432/postgres

# ── OR use individual fields (either DATABASE_URL or these) ──
# DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-supabase-db-password
# DB_SSL=true

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS: comma-separated allowed origins ────────────────────
# Add your Netlify URL here after deploying frontend
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-app.netlify.app
